generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    ADMIN
    MEMBER
}

enum ActionCategory {
    FINANCE
    OPERATIONS
    SALES_MARKETING
    PEOPLE
}

enum ActionStatus {
    PENDING
    COMPLETED
}

enum ToolButtonType {
    DOWNLOAD
    COMPLETE
}

enum ToolStatus {
    COMPLETE
    INCOMPLETE
}

model CognitoSubmission {
    id           String  @id @default(cuid())
    formId       String
    formTitle    String?
    userEmail    String
    payload      Json
    outputPdfUrl String?

    entryCreatedAt DateTime?
    entryUpdatedAt DateTime?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    @@unique([formId, userEmail])
    @@index([userEmail])
}

model AllowedAdminEmail {
    email     String   @id
    createdAt DateTime @default(now())
}

model User {
    id            String    @id @default(cuid())
    firstName     String?
    lastName      String?
    email         String    @unique
    emailVerified DateTime?
    phone         String?
    companyName   String?
    companyLogoUrl String?
    companyWebsite String?
    position      String?
    role          UserRole  @default(MEMBER)

    accounts Account[]
    sessions Session[]

    financialPeriodRecords  FinancialPeriodRecord[]
    cashFlows               CashFlow[]
    productivityRecords     ProductivityRecord[]
    ninetyDayActions        NinetyDayAction[]
    actionTools             ActionTool[]
    memberPerformanceNote   MemberPerformanceNote?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model CashFlow {
    id          String   @id @default(cuid())
    userEmail   String
    amount      Decimal
    includesVat String
    recordedAt  DateTime

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
}

model ProductivityRecord {
    id            String   @id @default(cuid())
    userEmail     String
    percentage    Float
    breakEvenRpp  Decimal?
    theMonthRpp   Decimal?
    targetFigure  Decimal?
    recordedAt    DateTime

    user User @relation(fields: [userEmail], references: [email])

    @@unique([userEmail])
}

model NinetyDayAction {
    id          String         @id @default(cuid())
    userEmail   String
    category    ActionCategory
    description String
    targetDate  DateTime
    status      ActionStatus   @default(PENDING)
    completedAt DateTime?
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
    @@unique([userEmail, category])
}

model ActionTool {
    id         String         @id @default(cuid())
    userEmail  String
    formId     String?
    label      String
    status     ToolStatus     @default(INCOMPLETE)
    buttonType ToolButtonType @default(COMPLETE)
    fileUrl    String?
    sortOrder  Int            @default(0)
    createdAt  DateTime       @default(now())
    updatedAt  DateTime       @updatedAt

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
    @@unique([userEmail, formId])
}

model FinancialPeriodRecord {
    id            String   @id @default(cuid())
    userEmail     String
    cycleNumber   Int      @default(1)
    periodNumber  Int      // 1-12
    month         String?  // e.g., "April"
    year          Int?     // e.g., 2026

    // Individual month values
    MonthGrossProfit         Decimal
    MonthRevenue             Decimal
    MonthNetProfit           Decimal
    MonthGrossProfitBudget   Decimal
    MonthRevenueBudget       Decimal
    MonthNetProfitBudget     Decimal
    MonthNetProfitPct        Float?
    MonthRevenuePct          Float?
    MonthGrossProfitPct      Float?

    // Accumulated YTD (sum of P1..Pn in same cycle)
    YTDGrossProfit           Decimal
    YTDRevenue               Decimal
    YTDNetProfit             Decimal
    YTDNetProfitBudget       Decimal
    YTDRevenueBudget         Decimal
    YTDGrossProfitBudget     Decimal
    YTDNetProfitPct          Float?
    YTDRevenuePct            Float?
    YTDGrossProfitPct        Float?

    currency   String   @default("GBP")
    recordedAt DateTime @default(now())

    user User @relation(fields: [userEmail], references: [email])

    @@unique([userEmail, cycleNumber, periodNumber])
    @@index([userEmail])
}

model MemberPerformanceNote {
    id        String   @id @default(cuid())
    userEmail String   @unique
    content   String
    updatedBy String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
}

model CognitoForm {
    id        String   @id @default(cuid())
    key       String   @unique
    formId    String   @unique
    title     String
    formUrl   String
    sortOrder Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AdminOtp {
    id        String    @id @default(cuid())
    email     String
    codeHash  String
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([email])
    @@index([expiresAt])
}

model MemberOtp {
    id        String    @id @default(cuid())
    email     String
    codeHash  String
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([email])
    @@index([expiresAt])
}
