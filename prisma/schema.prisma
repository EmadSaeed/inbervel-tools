generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    ADMIN
    MEMBER
}

enum FinancialMetricType {
    GROSS_PROFIT
    REVENUE
    NET_PROFIT
}

enum FinancialPeriod {
    MONTH
    YEAR
}

enum ActionCategory {
    FINANCE
    OPERATIONS
    SALES_MARKETING
    PEOPLE
}

enum ActionStatus {
    PENDING
    COMPLETED
}

enum ToolButtonType {
    DOWNLOAD
    COMPLETE
}

enum ToolStatus {
    COMPLETE
    INCOMPLETE
}

model CognitoSubmission {
    id           String  @id @default(cuid())
    formId       String
    formTitle    String?
    userEmail    String
    payload      Json
    outputPdfUrl String?

    entryCreatedAt DateTime?
    entryUpdatedAt DateTime?
    createdAt      DateTime  @default(now())
    updatedAt      DateTime  @updatedAt

    @@unique([formId, userEmail])
    @@index([userEmail])
}

model AllowedAdminEmail {
    email     String   @id
    createdAt DateTime @default(now())
}

model User {
    id            String    @id @default(cuid())
    firstName     String?
    lastName      String?
    email         String    @unique
    emailVerified DateTime?
    phone         String?
    companyName   String?
    companyLogoUrl String?
    companyWebsite String?
    position      String?
    role          UserRole  @default(MEMBER)

    accounts Account[]
    sessions Session[]

    financialMetrics    FinancialMetric[]
    cashFlows           CashFlow[]
    productivityRecords ProductivityRecord[]
    ninetyDayActions    NinetyDayAction[]
    actionTools         ActionTool[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model FinancialMetric {
    id         String              @id @default(cuid())
    userEmail  String
    type       FinancialMetricType
    period     FinancialPeriod
    value      Decimal
    percentage Float?
    currency   String              @default("GBP")
    recordedAt DateTime

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
}

model CashFlow {
    id          String   @id @default(cuid())
    userEmail   String
    amount      Decimal
    includesVat String
    recordedAt  DateTime

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
}

model ProductivityRecord {
    id            String   @id @default(cuid())
    userEmail     String
    percentage    Float
    breakEvenRpp  Decimal?
    theMonthRpp   Decimal?
    recordedAt    DateTime

    user User @relation(fields: [userEmail], references: [email])

    @@unique([userEmail])
}

model NinetyDayAction {
    id          String         @id @default(cuid())
    userEmail   String
    category    ActionCategory
    description String
    targetDate  DateTime
    status      ActionStatus   @default(PENDING)
    completedAt DateTime?
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
    @@unique([userEmail, category])
}

model ActionTool {
    id         String         @id @default(cuid())
    userEmail  String
    formId     String?
    label      String
    status     ToolStatus     @default(INCOMPLETE)
    buttonType ToolButtonType @default(COMPLETE)
    fileUrl    String?
    sortOrder  Int            @default(0)
    createdAt  DateTime       @default(now())
    updatedAt  DateTime       @updatedAt

    user User @relation(fields: [userEmail], references: [email])

    @@index([userEmail])
    @@unique([userEmail, formId])
}

model CognitoForm {
    id        String   @id @default(cuid())
    key       String   @unique
    formId    String   @unique
    title     String
    formUrl   String
    sortOrder Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AdminOtp {
    id        String    @id @default(cuid())
    email     String
    codeHash  String
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([email])
    @@index([expiresAt])
}

model MemberOtp {
    id        String    @id @default(cuid())
    email     String
    codeHash  String
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([email])
    @@index([expiresAt])
}
